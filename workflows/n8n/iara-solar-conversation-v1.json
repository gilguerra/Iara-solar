        "query": "insert into conversation.conversation_sessions (\n  session_id,\n  channel,\n  channel_user_id,\n  context_json,\n  created_at,\n  updated_at\n)\nvalues (\n  $1,\n  $2,\n  $3,\n  $4::jsonb,\n  now(),\n  now()\n)\nreturning *;",
        "options": {
          "queryReplacement": "={{ $json.sessionId }},{{ $json.channel }},{{ $json.channelUserId }},{{ $json.context }}"
        }
      },
