      "id": "0243a2a1-2ea4-4bac-b13b-15b65bc12734",
      "name": "Is New Session",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "const ctx = $json.context || {};\n\n// garantir estrutura mínima\nctx.lead = ctx.lead || {};\nctx.energy = ctx.energy || {};\nctx.installation = ctx.installation || {};\nctx.location = ctx.location || {};\nctx.conversation = ctx.conversation || {};\n\n// registrar última mensagem\nctx.conversation.last_user_message = $json.messageText || null;\n\n// --------- calcular missing fields ---------\nconst missing = [];\n\n// nome\nif (!ctx.lead.full_name) {\n  missing.push('full_name');\n}\n\n// energia\nconst hasEnergy =\n  !!ctx.energy.monthly_consumption_kwh ||\n  !!ctx.energy.bill_amount_brl ||\n  !!ctx.energy.bill_document_received;\n\nif (!hasEnergy) {\n  missing.push('bill_document_or_energy_data');\n}\n\n// tipo de instalação\nif (!ctx.installation.installation_type) {\n  missing.push('installation_type');\n}\n\n// tipo de cobertura\nif (!ctx.installation.roof_type) {\n  missing.push('roof_type');\n}\n\n// localização\nconst hasLocation =\n  !!ctx.lead.address_text ||\n  (!!ctx.lead.city && !!ctx.lead.state);\n\nif (!hasLocation) {\n  missing.push('location');\n}\n\n// salvar no contexto\nctx.conversation.missing_fields = missing;\n\n// --------- gerar resposta ---------\nlet reply = 'Olá! Eu sou a Iara Solar e posso montar uma estimativa inicial do seu sistema.';\n\nif (missing.includes('bill_document_or_energy_data')) {\n  reply += ' Me envie a conta de luz da Neoenergia em PDF ou foto para eu analisar seu consumo e o valor médio.';\n} else if (missing.includes('location')) {\n  reply += ' Agora me diga onde fica o imóvel, pelo menos cidade e estado.';\n} else if (missing.includes('installation_type')) {\n  reply += ' A instalação será no telhado ou no solo?';\n} else if (missing.includes('roof_type')) {\n  reply += ' Qual é o tipo de cobertura ou estrutura disponível?';\n} else if (missing.includes('full_name')) {\n  reply += ' Qual é o seu nome completo?';\n} else {\n  reply += ' Já tenho os dados mínimos para avançar com a simulação.';\n}\n\n// registrar última resposta\nctx.conversation.last_bot_message = reply;\n\n// --------- saída ---------\nreturn [\n  {\n    json: {\n      ...$json,\n      context: ctx,\n      outboundText: reply\n    }\n  }\n];"
      },
