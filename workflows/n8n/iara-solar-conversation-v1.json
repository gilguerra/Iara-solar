    {
      "parameters": {
        "jsCode": "if (!$json.sessionId) {\n  throw new Error('sessionId não encontrado no fluxo');\n}\n\nreturn [\n  {\n    json: {\n      session_id: $json.sessionId,\n      direction: 'outbound',\n      message_text: $json.outboundText || '',\n      payload_json: {\n        sessionId: $json.sessionId,\n        reply: $json.outboundText || '',\n        generatedAt: new Date().toISOString()\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -464,
        -160
      ],
      "id": "a259b6c8-bedd-4f70-9926-98aea0b51a19",
      "name": "Prepare Outbound Message Row"
    },
    {
      "parameters": {
        "jsCode": "const normalized = $('Normalize Input').first().json;\nconst dbRow = $json; // saída do Load Session\n\nlet context;\nlet isNew = false;\n\nif (!dbRow || !dbRow.session_id) {\n  // sessão não existe\n  isNew = true;\n\n  context = {\n    session_id: normalized.sessionId,\n    channel: normalized.channel,\n    channel_user_id: normalized.channelUserId,\n    stage: \"discovery\",\n    lead: {},\n    energy: {},\n    installation: {},\n    location: {},\n    backend: {},\n    conversation: {\n      missing_fields: []\n    }\n  };\n} else {\n  // sessão existe\n  context = dbRow.context_json || {};\n}\n\nreturn [{\n  json: {\n    ...normalized,\n    sessionId: normalized.sessionId,\n    context,\n    isNewSession: isNew\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -784,
        -320
      ],
